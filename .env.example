# Required
OPENAI_API_KEY=sk-your-api-key-here

# Optional (with defaults)
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_RETRIES=2
DIGEST_OUTPUT_FILE=news.md
DIGEST_STATUS_FILE=digest-run-status.json
# Optional for repo-local issue preflight/publish. Leave unset to use local `gh` auth.
# GITHUB_TOKEN=github_pat_your_token_here
PAPER_LIMIT=7
MAX_ITEMS_PER_SOURCE=6
RSS_TIMEOUT=10
RSS_RETRIES=2
RSS_MAX_WORKERS=8
RSS_MAX_FEED_BYTES=5000000
LOG_LEVEL=INFO
